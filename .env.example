# Copy this file to .env and fill in your mailbox settings.
#
# For Gmail or Outlook, you will usually want an app password instead of
# your normal account password. Keep the real .env file out of git.

IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=your.email@example.com
IMAP_PASSWORD=your-app-password
IMAP_MAILBOX=INBOX

# How far back the first run should look if there is no saved sync state.
LOOKBACK_DAYS=45
MAX_EMAILS=200

# Comma-separated terms used to cheaply filter emails before asking Ollama.
EMAIL_KEYWORDS=thank you for applying,thanks for applying,received your application,application has been received,your application,application status,interview,schedule a call,phone screen,assessment,coding challenge,take-home,technical exercise,offer,unfortunately,not moving forward,no longer under consideration,next steps

# Subject/from phrases that are usually job alerts, not updates about your applications.
EMAIL_EXCLUDE_KEYWORDS=jobs for you,more jobs in,job alert,recommended job,recommended jobs,apply now,new jobs,similar jobs,based on your profile,because you viewed,who is hiring,latest jobs,job recommendations,hiring now,weekly job,saved search alert

# Local model settings. Start Ollama before running sync.
USE_OLLAMA=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=120

DATA_DIR=data
OUTPUT_EXCEL=data/job_applications.xlsx
STATE_FILE=data/state.json
